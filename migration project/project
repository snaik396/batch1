# 1) Convert Data types and clean data

from pyspark.sql.functions import col

transaction_df = transaction_df.select(
    col("transaction_id").cast("int"),
    col("customer_id").cast("int"),
    col("product_id").cast("int"),
    col("store_id").cast("int"),
    col("quantity").cast("int"),
    col("transaction_date").cast("date")
)

product_df = product_df.select(
    col("product_id").cast("int"),
    col("product_name"),
    col("category"),
    col("price").cast("double")
)

store_df = store_df.select(
    col("store_id").cast("int"),
    col("store_name"),
    col("location")
)

customer_df = customer_df.select(
    "customer_id", "first_name", "last_name", "email", "city", "registration_date"
).dropDuplicates(["customer_id"])





# 2)  Join all data
df_silver = transaction_df \
    .join(customer_df, "customer_id") \
    .join(product_df, "product_id") \
    .join(store_df, "store_id") \
    .withColumn("total_amount", col("quantity") * col("price"))


display(df_silver)






# 3) dump to adls location
silver_path = "abfss://retail@pocstorageswap.dfs.core.windows.net/silver"

df_silver.write.mode("overwrite").format("delta").save(silver_path)






# 4) create silver dataset
spark.sql(f"""
CREATE TABLE retail_silver_cleaned
USING DELTA
LOCATION 'abfss://retail@pocstorageswap.dfs.core.windows.net/silver'
""")

%sql
select * from retail_silver_cleaned



# Load cleaned transactions from Silver layer
silver_df = spark.read.format("delta").load("abfss://retail@pocstorageswap.dfs.core.windows.net/silver")

silver_df.display()



from pyspark.sql.functions import sum, countDistinct, avg

gold_df = silver_df.groupBy(
    "transaction_date",
    "product_id", "product_name", "category",
    "store_id", "store_name", "location"
).agg(
    sum("quantity").alias("total_quantity_sold"),
    sum("total_amount").alias("total_sales_amount"),
    countDistinct("transaction_id").alias("number_of_transactions"),
    avg("total_amount").alias("average_transaction_value")
)


gold_df.display()





gold_path = "abfss://retail@pocstorageswap.dfs.core.windows.net/gold"

gold_df.write.mode("overwrite").format("delta").save(gold_path)


spark.sql("""
